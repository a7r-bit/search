enum NodeType {
  DIRECTORY
  DOCUMENT
}

enum ConversionStatus {
  PENDING
  IN_PROGRESS
  DONE
  FAILED
}

// -------------------
// CORE MODEL: NODE
// -------------------
model Node {
  id          String   @id @default(uuid()) @db.Uuid
  type        NodeType
  parentId    String?  @map("parent_id") @db.Uuid
  parent      Node?    @relation("NodeToNode", fields: [parentId], references: [id])
  children    Node[]   @relation("NodeToNode")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  documentDetails       DocumentDetails?
  likedBy               LikedNode[]
  documentDetailsNodeId String?          @db.Uuid

  @@unique([parentId, name])
  @@index([parentId])
  @@index([type])
  @@map("nodes")
}

// -------------------
// DETAILS
// -------------------
model DocumentDetails {
  nodeId   String            @id @map("node_id") @db.Uuid
  node     Node              @relation(fields: [nodeId], references: [id])
  versions DocumentVersion[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("document_details")
}

model DocumentVersion {
  id               String           @id @default(uuid()) @db.Uuid
  version          Int
  documentNodeId   String           @map("document_id") @db.Uuid
  document         DocumentDetails  @relation(fields: [documentNodeId], references: [nodeId])
  mediaFile        MediaFile?
  conversionStatus ConversionStatus @default(PENDING) @map("conversion_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([version, documentNodeId])
  @@map("document_versions")
}

model MediaFile {
  id                String           @id @default(uuid()) @db.Uuid
  filePath          String           @map("file_path")
  fileName          String           @map("file_name")
  extention         String
  documentVersionId String?          @unique @map("document_version_id") @db.Uuid
  documentVersion   DocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("media_file")
}

model LikedNode {
  id String @id @default(uuid()) @db.Uuid

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  nodeId String @map("node_id") @db.Uuid
  node   Node   @relation(fields: [nodeId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("liked_nodes")
}

